---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";
import { getCollection } from "astro:content";
import Footer from "../components/Footer.astro";
import { Image } from "astro:assets";
import profileImage from "../assets/profile.png";

const allProjects = await getCollection("projects");
const allWriting = await getCollection("writing");
const allReading = await getCollection("reading");

const projects = allProjects
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  // Transform string to Date object
  .filter((project) => project.data.isFeatured)
  .slice(0, 3);

const totalProjects = allProjects.length;
const totalWriting = allWriting.length;
const totalReading = allReading.length;

const writing = allWriting
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 12);

const reading = allReading
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const workStartDate = new Date("2020-03-01");
const workExperience = new Date().getFullYear() - workStartDate.getFullYear();

const achievements = [
  {
    title: "RunnerUp in Govhack 2025",
    pubDate: new Date("2025-12-10"),
    link: "https://www.linkedin.com/posts/koso-bilegsaikhan_excited-to-share-that-our-team-gridunlocked-activity-7403323655696605184-b2oL?utm_source=share&utm_medium=member_desktop&rcm=ACoAAD3MwKEB5HL9rLW_5PL5lC91RwFgCI9gRJs",
  },
  {
    title: "National News Appearance during DX-Cup 2023",
    pubDate: new Date("2023-06-01"),
    link: "https://www.youtube.com/watch?v=vscV4DMRbnI",
  },
  {
    title: "Top 3 Scorer in Mongolia in ITPEC FE 2022",
    pubDate: new Date("2022-04-10"),
    link: "https://itpec.org/statsandresults/high-score-passers-202204.html",
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main class="w-full">
      <div class="w-full mt-32 px-12 md:px-16 lg:px-8 md:max-w-6xl md:mx-auto">
        <div class="flex flex-col items-center md:flex-row md:items-start">
          <div class="w-full lg:w-2/3">
            <h3 class="text-lg">ABOUT</h3>
            <h1 class="text-4xl font-bold">Koso Bilegsaikhan</h1>
            <div class="flex flex-col gap-4 mt-4">
              <p>
                I'm a Full-Stack Engineer with over
                {workExperience} years of professional experience based in Sydney,
                NSW. My red flag is reading a sci-fi, cautionary tale and saying:
                I kinda wanna make it.
              </p>
              <p>
                I know a little bit of everything, but know a bunch about
                software architecture, backend and DevOps. Followed up by web,
                mobile, AI, SaaS, Cloud, Infra etc. If you can name it, I
                probably know at least a little about it. If I'm quiet for any
                extended amount of time, that's probably me researching about it
                until I seem like I know a bit about it.
              </p>
            </div>
            <div class="mt-8"></div>
          </div>
          <div class="hidden lg:flex lg:w-1/3 justify-end">
            <Image
              src={profileImage}
              alt="Profile"
              width={300}
              height={300}
              class="rounded-full"
            />
          </div>
        </div>
        <h3 class="text-lg">FEATURED PROJECTS</h3>
        <div class="flex justify-between items-end">
          <h1 class="text-4xl font-bold">Case Studies</h1>
          <a
            href="/projects"
            class="text-sm text-gray-500 hover:underline align-bottom"
            >View All ({totalProjects})</a
          >
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mt-8">
          {
            projects.map((project, idx) => (
              <div
                class:list={[
                  "bg-gray-900 hover:scale-103 transition-all duration-200 rounded-2xl overflow-hidden flex flex-col",
                  idx === 2 && "md:hidden lg:flex",
                ]}
                onclick={`window.location.href = '/projects/${project.id}'`}
              >
                <div class="h-[250px] w-full bg-gray-800 flex justify-center items-center overflow-hidden">
                  {project.data.heroImage && (
                    <Image
                      class="object-contain"
                      width={1000}
                      height={250}
                      src={project.data.heroImage}
                      alt={project.data.title}
                    />
                  )}
                </div>
                <div class="p-6 flex flex-col justify-between gap-2">
                  <div class="flex justify-between items-center">
                    <p>{project.data.type || "PROJECT"}</p>
                    <p>
                      {project.data.pubDate
                        .toLocaleDateString("en-US", {
                          month: "short",
                          year: "numeric",
                        })
                        .toUpperCase()}
                    </p>
                  </div>
                  <h1 class="text-2xl font-medium">{project.data.title}</h1>
                  <p class="font-light">{project.data.description}</p>
                </div>
              </div>
            ))
          }
        </div>
        <div class="mt-16"></div>
        <h3 class="text-lg">WRITING</h3>
        <div class="flex justify-between items-end">
          <h1 class="text-4xl font-bold">Blog posts</h1>
          <a
            href="/writing"
            class="text-sm text-gray-500 hover:underline align-bottom"
            >View All ({totalWriting})</a
          >
        </div>
        <div class="flex flex-col gap-4 mt-8">
          {
            writing.map((writing) => (
              <a href={`/writing/${writing.id}`}>
                <h1 class="text-lg font-medium hover:underline">
                  {writing.data.pubDate.toLocaleDateString("en-US", {
                    month: "short",
                    year: "numeric",
                  })}{" "}
                  • {writing.data.title}
                </h1>
              </a>
            ))
          }
        </div>
        <div class="mt-16"></div>
        <h3 class="text-lg">READING</h3>
        <div class="flex justify-between items-end">
          <h1 class="text-4xl font-bold">Media Consumption</h1>
          <a
            href="/reading"
            class="text-sm text-gray-500 hover:underline align-bottom"
            >View All ({totalReading})</a
          >
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mt-8">
          {
            reading.map((reading, idx) => (
              <div
                class:list={[
                  "bg-gray-900 hover:scale-103 transition-all duration-200 rounded-2xl overflow-hidden flex flex-col",
                  idx === 2 && "md:hidden lg:flex",
                ]}
                onclick={`window.location.href = '/reading/${reading.id}'`}
              >
                <div
                  class="h-[500px] w-full bg-gray-800 flex justify-center items-center overflow-hidden object-contain

"
                >
                  {reading.data.heroImage && (
                    <Image
                      class="object-contain"
                      src={reading.data.heroImage}
                      alt={reading.data.title}
                      width={1000}
                      height={250}
                    />
                  )}
                </div>
              </div>
            ))
          }
        </div>
        <div class="mt-16"></div>
        <h3 class="text-lg">ACHIEVEMENTS</h3>
        <h1 class="text-4xl font-bold">Digital Footprint</h1>
        <div class="flex flex-col gap-4 mt-8">
          {
            achievements.map((achievement) => (
              <a
                href={achievement.link}
                target="_blank"
                rel="noopener noreferrer"
              >
                <h1 class="text-lg font-medium hover:underline">
                  {achievement.pubDate.toLocaleDateString("en-US", {
                    month: "short",
                    year: "numeric",
                  })}{" "}
                  • {achievement.title}
                </h1>
              </a>
            ))
          }
        </div>
        <div class="mt-16"></div>
      </div>
    </main>
    <Footer />
  </body>
</html>
