---
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import BaseHead from "../../components/BaseHead.astro";
import Footer from "../../components/Footer.astro";
import FormattedDate from "../../components/FormattedDate.astro";
import Header from "../../components/Header.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../../consts";

const projects = (await getCollection("projects")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main
      class="w-full mt-32 px-16 lg:px-4 md:max-w-6xl md:mx-auto min-h-[70vh]"
    >
      <h3 class="text-lg">PROJECTS</h3>
      <h1 class="text-4xl font-bold">Case Studies</h1>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mt-8">
        {
          projects.map((project, idx) => (
            <div
              class:list={[
                "bg-gray-900 hover:scale-103 transition-all duration-200 rounded-2xl overflow-hidden flex flex-col",
              ]}
              onclick={`window.location.href = '/projects/${project.id}'`}
            >
              <div class="h-[250px] w-full bg-gray-800 flex justify-center items-center">
                <Image
                  width={1000}
                  height={250}
                  src={
                    (
                      {
                        src: project.data.heroImage,
                      } as unknown as ImageMetadata
                    ).src ??
                    "https://stantyan.com/assets/blog/subscription-metrics/subscription-metrics-preview.CdQwwudZ_zWVAP.webp"
                  }
                  alt={project.data.title}
                  class="object-cover"
                />
              </div>
              <div class="p-6 flex flex-col justify-between gap-2">
                <div class="flex justify-between items-center">
                  <p>{project.data.type || "PROJECT"}</p>
                  <p>MAR 2025</p>
                </div>
                <h1 class="text-2xl font-medium">{project.data.title}</h1>
                <p class="font-light">{project.data.description}</p>
              </div>
            </div>
          ))
        }
      </div>
      <div class="mt-16"></div>
    </main>
    <Footer />
  </body>
</html>
