---
import { type CollectionEntry, getCollection, render } from "astro:content";
import BaseHead from "../../components/BaseHead.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../../consts";
import { Image } from "astro:assets";

export async function getStaticPaths() {
  const projects = await getCollection("projects");
  return projects.map((project) => ({
    params: { slug: project.id },
    props: project,
  }));
}
type Props = CollectionEntry<"projects">;

const project = Astro.props;
const { Content } = await render(project);
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main>
      <article
        class="w-full mt-16 px-16 lg:px-4 md:max-w-6xl md:mx-auto min-h-[70vh]"
      >
        <h3 class="text-lg">{project.data.type || "PROJECT"}</h3>
        <h1 class="mt-4 text-4xl font-semibold">{project.data.title}</h1>
        <div class="mt-4 flex gap-2 text-sm">
          <p>By Koso Bilegsaikhan</p>
          <p>•</p>
          <p>
            Published {
              project.data.pubDate.toLocaleDateString("en-US", {
                month: "short",
                year: "numeric",
              })
            }
          </p>
        </div>

        <p class="mt-4 text-gray-500">{project.data.description}</p>
        <div class="mt-4 overflow-hidden rounded-lg w-full h-[300px]">
          {
            project.data.heroImage && (
              <Image
                width={1000}
                height={500}
                src={project.data.heroImage}
                alt={project.data.title}
                class="object-contain"
              />
            )
          }
        </div>
        <div class="mt-16"></div>
        <div class="md-content">
          <Content />
        </div>
      </article>
    </main>
    <Footer />
  </body>
</html>
