---
import { type CollectionEntry, getCollection, render } from "astro:content";
import BaseHead from "../../components/BaseHead.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { SITE_TITLE } from "../../consts";
import { Image } from "astro:assets";

export async function getStaticPaths() {
  const projects = await getCollection("projects");
  return projects.map((project) => ({
    params: { slug: project.id },
    props: project,
  }));
}
type Props = CollectionEntry<"projects">;

const project = Astro.props;
const { Content } = await render(project);
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title={project.data.title + " | " + SITE_TITLE}
      description={project.data.description}
      image={project.data.heroImage}
    />
  </head>
  <body>
    <Header />
    <main>
      <article
        class="w-full mt-16 px-12 md:px-16 lg:px-8 md:max-w-6xl md:mx-auto min-h-[70vh]"
      >
        <h3 class="text-lg">{project.data.type || "PROJECT"}</h3>
        <h1 class="mt-4 text-4xl font-semibold">{project.data.title}</h1>
        <div class="mt-4 mb-4 flex gap-2 text-sm">
          <p>By Koso Bilegsaikhan</p>
          <p>•</p>
          <p>
            Published {
              project.data.pubDate.toLocaleDateString("en-US", {
                month: "short",
                year: "numeric",
              })
            }
          </p>
        </div>
        <div class="md-content">
          <Content />
        </div>
      </article>
      <div class="mt-16"></div>
    </main>
    <Footer />
  </body>
</html>
