---
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import BaseHead from "../../components/BaseHead.astro";
import Footer from "../../components/Footer.astro";
import Header from "../../components/Header.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../../consts";

const reading = (await getCollection("reading")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main
      class="w-full mt-32 px-16 lg:px-4 md:max-w-6xl md:mx-auto min-h-[70vh]"
    >
      <h3 class="text-lg">READING</h3>
      <h1 class="text-4xl font-bold">Media Consumption</h1>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mt-8">
        {
          reading.map((reading, idx) => (
            <div
              class:list={[
                "bg-gray-900 hover:scale-103 transition-all duration-200 rounded-2xl overflow-hidden flex flex-col",
              ]}
              onclick={`window.location.href = '/reading/${reading.id}'`}
            >
              <div class="h-[500px] w-full bg-gray-800 flex justify-center items-center overflow-hidden">
                {reading.data.heroImage && (
                  <Image
                    width={1000}
                    height={250}
                    src={reading.data.heroImage}
                    alt={reading.data.title}
                    class="object-cover"
                  />
                )}
              </div>
            </div>
          ))
        }
      </div>
      <div class="mt-16"></div>
    </main>
    <Footer />
  </body>
</html>
