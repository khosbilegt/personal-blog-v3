---
import BaseHead from "../../components/BaseHead.astro";
import Footer from "../../components/Footer.astro";
import Header from "../../components/Header.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../../consts";

const email = "khosbilegt.b@gmail.com";
const upworkLink = "https://www.upwork.com/freelancers/~0172b70dee77e4cfd8";

const workTypes = [
  {
    title: "Hourly collaboration",
    price: 30,
    priceUnit: "hour",
    features: [
      "Short-term debugging",
      "Small-scale feature development",
      "Quick technical support",
    ],
  },
  {
    title: "One-time project",
    price: "1,500+",
    priceUnit: "project",
    features: [
      "Small projects such as landing pages, blogs, etc.",
      "Minor functionality such as Shopify integrations, CRM, etc",
    ],
  },
  {
    title: "Long-term project",
    price: "3,000+",
    priceUnit: "month",
    features: [
      "Medium to large projects such as SaaS, e-commerce, etc.",
      "Complex functionality such as AI, ML, etc",
    ],
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main
      class="w-full mt-32 px-16 lg:px-4 md:max-w-6xl md:mx-auto min-h-[70vh]"
    >
      <h3 class="text-lg">Contact</h3>
      <h1 class="text-4xl font-bold">Get in touch</h1>

      <div class="flex flex-col gap-4 mt-8">
        <p>
          Hey there, I'm currently open to freelance contracts, collaborations
          and new opportunities.
        </p>
        <p>
          My preferred platform is Upwork at the moment to build up my profile,
          but feel free to reach out to me via email and we can arrange
          something.
        </p>
        <div class="flex justify-center items-center gap-4 mt-8">
          {
            workTypes.map((workType) => (
              <div class="w-[400px] h-[450px] bg-gray-900 transition-all duration-200 rounded-2xl overflow-hidden flex flex-col p-6 justify-between">
                <div>
                  <p class="text-lg font-medium text-center">
                    {workType.title}
                  </p>
                  <div class="flex items-center gap-2 justify-center mt-5">
                    <p>$</p>
                    <p class="text-3xl text-gray-500">{workType.price}</p>
                    <p>/{workType.priceUnit}</p>
                  </div>
                </div>
                <ul class="mt-8 ml-8 space-y-3 text-white w-[250px]">
                  {workType.features.map((feature) => (
                    <li class="flex items-start gap-3">
                      <svg
                        class="mt-1 size-5 shrink-0 text-blue-400"
                        viewBox="0 0 20 20"
                        fill="currentColor"
                        aria-hidden="true"
                      >
                        <path
                          fill-rule="evenodd"
                          d="M16.704 5.29a1 1 0 0 1 .006 1.414l-7.5 7.571a1 1 0 0 1-1.42.002L3.29 9.777a1 1 0 1 1 1.414-1.414l3.377 3.377 6.793-6.86a1 1 0 0 1 1.43-.01Z"
                          clip-rule="evenodd"
                        />
                      </svg>
                      <span>{feature}</span>
                    </li>
                  ))}
                </ul>
                <div class="flex flex-col gap-4 mt-8 justify-center items-center">
                  <a
                    href={upworkLink}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="bg-blue-500 text-white px-4 py-2 rounded-md hover:bg-blue-600 transition-all duration-200 w-[250px] justify-center inline-flex items-center gap-2"
                  >
                    <span class="inline-flex size-5 shrink-0 items-center justify-center">
                      <img
                        src="https://uxwing.com/wp-content/themes/uxwing/download/brands-and-social-media/upwork-icon.png"
                        alt=""
                        class="size-5"
                        loading="lazy"
                        decoding="async"
                        referrerpolicy="no-referrer"
                      />
                    </span>
                    <span>Visit on Upwork</span>
                  </a>
                  <a
                    href={`mailto:${email}`}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="bg-gray-900 border border-gray-800 hover:bg-gray-800 text-white px-4 py-2 rounded-md transition-all duration-200 w-[250px] justify-center inline-flex items-center gap-2"
                  >
                    <span class="inline-flex size-5 shrink-0 items-center justify-center">
                      <svg
                        class="size-5 text-gray-200"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        aria-hidden="true"
                      >
                        <path d="M4 6h16v12H4z" />
                        <path d="m22 7-10 7L2 7" />
                      </svg>
                    </span>
                    <span>Send email</span>
                  </a>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </main>
    <div class="mt-16"></div>
    <Footer />
  </body>
</html>
