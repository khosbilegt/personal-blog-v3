---
import BaseHead from "../../components/BaseHead.astro";
import Footer from "../../components/Footer.astro";
import Header from "../../components/Header.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../../consts";

const email = "khosbilegt.b@gmail.com";
const upworkLink = "https://www.upwork.com/freelancers/~0172b70dee77e4cfd8";

const workTypes = [
  {
    title: "Hourly collaboration",
    price: 30,
    priceUnit: "hour",
    features: [
      "Short-term debugging",
      "Small-scale feature development",
      "Quick technical support",
    ],
  },
  {
    title: "One-time project",
    price: "1,500+",
    priceUnit: "project",
    features: [
      "Small projects such as landing pages, blogs, etc.",
      "Minor functionality such as Shopify integrations, CRM, etc",
    ],
  },
  {
    title: "Long-term project",
    price: "3,000+",
    priceUnit: "month",
    features: [
      "Medium to large projects such as SaaS, e-commerce, etc.",
      "Complex functionality such as AI, ML, etc",
    ],
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main
      class="w-full mt-32 px-12 md:px-16 lg:px-8 md:max-w-6xl md:mx-auto min-h-[70vh]"
    >
      <h3 class="text-lg">Contact</h3>
      <h1 class="text-4xl font-bold">Get in touch</h1>

      <div class="flex flex-col gap-4 mt-8">
        <p>
          Hey there, I'm currently open to freelance contracts, collaborations
          and new opportunities.
        </p>
        <p>
          My preferred platform is Upwork at the moment to build up my profile,
          but feel free to reach out to me via email and we can arrange
          something.
        </p>
        <div
          class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 mt-8 items-stretch"
        >
          {
            workTypes.map((workType) => (
              <div class="w-full min-h-[450px] bg-gray-900 transition-all duration-200 rounded-2xl overflow-hidden flex flex-col p-6 justify-between">
                <div>
                  <p class="text-lg font-medium text-center">
                    {workType.title}
                  </p>
                  <div class="flex items-center gap-2 justify-center mt-5">
                    <p>$</p>
                    <p class="text-3xl text-gray-500">{workType.price}</p>
                    <p>/{workType.priceUnit}</p>
                  </div>
                </div>
                <ul class="mt-8 mx-auto space-y-3 text-white w-full max-w-[250px]">
                  {workType.features.map((feature) => (
                    <li class="flex items-start gap-3">
                      <svg
                        class="mt-1 size-5 shrink-0 text-blue-400"
                        viewBox="0 0 20 20"
                        fill="currentColor"
                        aria-hidden="true"
                      >
                        <path
                          fill-rule="evenodd"
                          d="M16.704 5.29a1 1 0 0 1 .006 1.414l-7.5 7.571a1 1 0 0 1-1.42.002L3.29 9.777a1 1 0 1 1 1.414-1.414l3.377 3.377 6.793-6.86a1 1 0 0 1 1.43-.01Z"
                          clip-rule="evenodd"
                        />
                      </svg>
                      <span>{feature}</span>
                    </li>
                  ))}
                </ul>
                <div class="flex flex-col gap-4 mt-8 justify-center items-center">
                  <a
                    href={upworkLink}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="bg-blue-500 text-white px-4 py-2 rounded-md hover:bg-blue-600 transition-all duration-200 w-full max-w-[250px] justify-center inline-flex items-center gap-2"
                  >
                    <span class="inline-flex size-5 shrink-0 items-center justify-center">
                      <img
                        src="https://uxwing.com/wp-content/themes/uxwing/download/brands-and-social-media/upwork-icon.png"
                        alt=""
                        class="size-5"
                        loading="lazy"
                        decoding="async"
                        referrerpolicy="no-referrer"
                      />
                    </span>
                    <span>Visit on Upwork</span>
                  </a>
                  <div class="relative w-full max-w-[250px]">
                    <a
                      href={`mailto:${email}`}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="bg-gray-900 border border-gray-800 hover:bg-gray-800 text-white px-4 py-2 pr-12 rounded-md transition-all duration-200 w-full justify-center inline-flex items-center gap-2"
                    >
                      <span class="inline-flex size-5 shrink-0 items-center justify-center">
                        <svg
                          class="size-5 text-gray-200"
                          viewBox="0 0 24 24"
                          fill="none"
                          stroke="currentColor"
                          stroke-width="2"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          aria-hidden="true"
                        >
                          <path d="M4 6h16v12H4z" />
                          <path d="m22 7-10 7L2 7" />
                        </svg>
                      </span>
                      <span>Send email</span>
                    </a>

                    <button
                      type="button"
                      aria-label="Copy email"
                      class="group absolute right-2 top-1/2 -translate-y-1/2 inline-flex size-8 items-center justify-center rounded-md border border-gray-800 bg-gray-900 hover:bg-gray-800 transition-all duration-200"
                      data-copy-email-button
                      data-copy-value={email}
                    >
                      <svg
                        class="size-4 text-gray-200"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        aria-hidden="true"
                      >
                        <rect x="9" y="9" width="13" height="13" rx="2" />
                        <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" />
                      </svg>

                      <span
                        class="pointer-events-none absolute -top-8 right-0 hidden whitespace-nowrap rounded-md border border-gray-800 bg-gray-950 px-2 py-1 text-xs text-gray-100 shadow-sm"
                        role="status"
                        aria-live="polite"
                        data-copy-tooltip
                      >
                        Email has been copied to clipboard
                      </span>
                    </button>
                  </div>
                </div>
              </div>
            ))
          }
          <div
            class="w-full min-h-[250px] h-auto bg-gray-900 transition-all duration-200 rounded-2xl overflow-hidden flex flex-col p-6 gap-4 md:min-h-0 lg:col-span-3"
          >
            <h2 class="text-2xl font-medium">Full-time position</h2>
            <p>
              I'm currently working at a startup as a Founding Engineer and got
              a pretty decent gig going; but obviously I'm open to global remote
              opportunities or local positions in Australia. Open to flying over
              to Singapore or Europe if I get a cool job.
            </p>
            <p>
              If you think I'm cool and want to offer me a position, please note
              that I'm currently an <span class="underline"
                >international student</span
              > in Sydney, NSW. If you want to throw a sponsorship my way, I'll come
              running.
            </p>
            <div
              class="mt-2 flex lg:flex-row flex-col gap-4 justify-center items-center lg:justify-start"
            >
              <a
                href="https://www.linkedin.com/in/koso-bilegsaikhan/"
                target="_blank"
                rel="noopener noreferrer"
                class="bg-blue-500 text-white px-4 py-2 rounded-md hover:bg-blue-600 transition-all duration-200 w-full max-w-[250px] justify-center inline-flex items-center gap-2"
              >
                <span
                  class="inline-flex size-5 shrink-0 items-center justify-center"
                >
                  <img
                    src="https://upload.wikimedia.org/wikipedia/commons/thumb/c/ca/LinkedIn_logo_initials.png/960px-LinkedIn_logo_initials.png"
                    alt=""
                    class="size-5"
                    loading="lazy"
                    decoding="async"
                    referrerpolicy="no-referrer"
                  />
                </span>
                <span>Visit on LinkedIn</span>
              </a>
              <div class="relative w-full max-w-[250px]">
                <a
                  href={`mailto:${email}`}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="bg-gray-900 border border-gray-800 hover:bg-gray-800 text-white px-4 py-2 pr-12 rounded-md transition-all duration-200 w-full justify-center inline-flex items-center gap-2"
                >
                  <span
                    class="inline-flex size-5 shrink-0 items-center justify-center"
                  >
                    <svg
                      class="size-5 text-gray-200"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      aria-hidden="true"
                    >
                      <path d="M4 6h16v12H4z"></path>
                      <path d="m22 7-10 7L2 7"></path>
                    </svg>
                  </span>
                  <span>Send email</span>
                </a>

                <button
                  type="button"
                  aria-label="Copy email"
                  class="group absolute right-2 top-1/2 -translate-y-1/2 inline-flex size-8 items-center justify-center rounded-md border border-gray-800 bg-gray-900 hover:bg-gray-800 transition-all duration-200"
                  data-copy-email-button
                  data-copy-value={email}
                >
                  <svg
                    class="size-4 text-gray-200"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                  >
                    <rect x="9" y="9" width="13" height="13" rx="2"></rect>
                    <path
                      d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"
                    ></path>
                  </svg>

                  <span
                    class="pointer-events-none absolute -top-8 right-0 hidden whitespace-nowrap rounded-md border border-gray-800 bg-gray-950 px-2 py-1 text-xs text-gray-100 shadow-sm"
                    role="status"
                    aria-live="polite"
                    data-copy-tooltip
                  >
                    Email has been copied to clipboard
                  </span>
                </button>
              </div>
            </div>
          </div>
        </div>
      </div>
      <div class="mt-8">
        <p class="text-center text-gray-800">
          Disclaimer: Prices are estimates and may vary depending on the
          project. All prices are in USD.
        </p>
      </div>
    </main>
    <div class="mt-16"></div>
    <Footer />

    <script is:inline>
      const COPY_TOOLTIP_HIDE_DELAY_MS = 1200;

      async function copyTextToClipboard(text) {
        if (globalThis?.navigator?.clipboard?.writeText) {
          await navigator.clipboard.writeText(text);
          return;
        }

        const textarea = document.createElement("textarea");
        textarea.value = text;
        textarea.setAttribute("readonly", "");
        textarea.style.position = "fixed";
        textarea.style.left = "-9999px";
        textarea.style.top = "0";
        document.body.appendChild(textarea);
        textarea.select();
        document.execCommand("copy");
        document.body.removeChild(textarea);
      }

      function bindCopyEmailButtons() {
        document
          .querySelectorAll("[data-copy-email-button]")
          .forEach((buttonEl) => {
            if (buttonEl.dataset.copyBound === "true") return;
            buttonEl.dataset.copyBound = "true";

            buttonEl.addEventListener("click", async (e) => {
              e.preventDefault();
              e.stopPropagation();

              const value = buttonEl.getAttribute("data-copy-value") ?? "";
              if (!value) return;

              try {
                await copyTextToClipboard(value);

                const tooltip = buttonEl.querySelector("[data-copy-tooltip]");
                if (!tooltip) return;

                tooltip.classList.remove("hidden");
                window.clearTimeout(buttonEl.__copyTooltipTimeoutId);
                buttonEl.__copyTooltipTimeoutId = window.setTimeout(() => {
                  tooltip.classList.add("hidden");
                }, COPY_TOOLTIP_HIDE_DELAY_MS);
              } catch (err) {
                console.error("Failed to copy email", err);
              }
            });
          });
      }

      bindCopyEmailButtons();
      document.addEventListener("astro:page-load", bindCopyEmailButtons);
    </script>
  </body>
</html>
