---

---

<header class="w-full py-6">
  <nav
    class="w-full px-12 md:px-16 lg:px-8 md:max-w-6xl md:mx-auto flex items-center justify-between"
    aria-label="Primary"
  >
    <div class="hidden md:flex gap-6">
      <a class="hover:underline" href="/">About</a>
      <a class="hover:underline" href="/projects">Projects</a>
      <a class="hover:underline" href="/writing">Writing</a>
      <a class="hover:underline" href="/reading">Reading</a>
    </div>
    <div class="hidden md:flex gap-4">
      <a class="hover:underline" href="/contact">Contact</a>
      <a
        class="hover:underline"
        href="https://www.linkedin.com/in/koso-bilegsaikhan/">LinkedIn</a
      >
      <a
        class="hover:underline"
        href="/cv.pdf"
        target="_blank"
        rel="noopener noreferrer">Open CV (PDF)</a
      >
    </div>
    <button
      type="button"
      id="nav-menu-open"
      class="md:hidden ml-auto p-2 -mr-2 rounded-md text-gray-200 hover:bg-gray-800 hover:text-white transition-colors"
      aria-expanded="false"
      aria-controls="nav-mobile-drawer"
    >
      <span class="sr-only">Open menu</span>
      <svg
        class="size-6"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        viewBox="0 0 24 24"
        aria-hidden="true"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"></path>
      </svg>
    </button>
  </nav>

  <div
    id="nav-mobile-root"
    class="fixed inset-0 z-[100] md:hidden pointer-events-none"
    aria-hidden="true"
    data-open="false"
  >
    <button
      type="button"
      id="nav-menu-backdrop"
      class="absolute inset-0 bg-black/60 opacity-0 transition-opacity duration-200"
      tabindex="-1"
      aria-label="Close menu"></button>
    <aside
      id="nav-mobile-drawer"
      class="absolute right-0 top-0 flex h-full w-[min(18rem,85vw)] flex-col border-l border-gray-800 bg-gray-900 shadow-xl transition-transform duration-200 ease-out translate-x-full"
      aria-label="Mobile navigation"
    >
      <div
        class="flex items-center justify-between border-b border-gray-800 px-4 py-4"
      >
        <span class="text-md ml-2 font-medium text-gray-400">Menu</span>
        <button
          type="button"
          id="nav-menu-close"
          class="rounded-md p-2 text-gray-300 hover:bg-gray-800 hover:text-white transition-colors"
          aria-label="Close menu"
        >
          <svg
            class="size-5"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M6 18 18 6M6 6l12 12"></path>
          </svg>
        </button>
      </div>
      <nav class="flex flex-col gap-1 p-4">
        <a
          class="rounded-lg px-3 py-3 text-gray-200 hover:bg-gray-800 hover:text-white transition-colors nav-drawer-link"
          href="/">About</a
        >
        <a
          class="rounded-lg px-3 py-3 text-gray-200 hover:bg-gray-800 hover:text-white transition-colors nav-drawer-link"
          href="/projects">Projects</a
        >
        <a
          class="rounded-lg px-3 py-3 text-gray-200 hover:bg-gray-800 hover:text-white transition-colors nav-drawer-link"
          href="/writing">Writing</a
        >
        <a
          class="rounded-lg px-3 py-3 text-gray-200 hover:bg-gray-800 hover:text-white transition-colors nav-drawer-link"
          href="/reading">Reading</a
        >
        <div class="flex flex-col gap-2">
          <a
            class="rounded-lg px-3 py-3 text-gray-200 hover:bg-gray-800 hover:text-white transition-colors nav-drawer-link"
            href="https://www.linkedin.com/in/koso-bilegsaikhan/">LinkedIn</a
          >
        </div>
        <a
          class="mt-2 rounded-lg border bg-blue-500 border-gray-700 px-3 py-3 text-center text-gray-200 hover:bg-gray-800 hover:text-white transition-colors nav-drawer-link"
          href="/contact">Contact</a
        >
      </nav>
    </aside>
  </div>
</header>

<script>
  const root = document.getElementById("nav-mobile-root");
  const openBtn = document.getElementById("nav-menu-open");
  const closeBtn = document.getElementById("nav-menu-close");
  const backdrop = document.getElementById("nav-menu-backdrop");
  const drawer = document.getElementById("nav-mobile-drawer");
  const drawerLinks = document.querySelectorAll(".nav-drawer-link");

  if (root && openBtn && closeBtn && backdrop && drawer) {
    const setOpen = (open: boolean) => {
      root.dataset.open = open ? "true" : "false";
      root.setAttribute("aria-hidden", open ? "false" : "true");
      root.classList.toggle("pointer-events-none", !open);
      openBtn.setAttribute("aria-expanded", open ? "true" : "false");
      backdrop.classList.toggle("opacity-0", !open);
      drawer.classList.toggle("translate-x-full", !open);
      document.body.classList.toggle("overflow-hidden", open);
    };

    openBtn.addEventListener("click", () => setOpen(true));
    closeBtn.addEventListener("click", () => setOpen(false));
    backdrop.addEventListener("click", () => setOpen(false));

    drawerLinks.forEach((el) => {
      el.addEventListener("click", () => setOpen(false));
    });

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && root.dataset.open === "true") setOpen(false);
    });
  }
</script>
